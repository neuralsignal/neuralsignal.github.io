      "color": "#6B7280"
    },
    "view": {
      "stroke": null
    }
  },
  "title": "Cross-validated log-likelihood of four evolved candidates",
  "width": "container",
  "height": 260,
  "data": {
    "values": [
      {
        "run": "not normalized",
        "cv_ll": 9.29,
        "kind": "bug"
      },
      {
        "run": "3 params",
        "cv_ll": 3.318,
        "kind": "normalized"
      },
      {
        "run": "5 params",
        "cv_ll": 3.327,
        "kind": "normalized"
      },
      {
        "run": "9 params",
