  "spacing": 44,
  "hconcat": [
    {
      "width": 300,
      "height": 240,
      "layer": [
        {
          "mark": {
            "type": "bar",
            "cornerRadiusEnd": 2
          },
          "encoding": {
            "y": {
              "field": "dist",
              "type": "nominal",
              "title": null,
              "sort": {
                "field": "cv_ll",
                "order": "descending"
              },
              "axis": {
                "labelFontSize": 13
              }
            },
            "x": {
              "field": "cv_ll",
              "type": "quantitative",
              "title": "Log-likelihood per day (higher is better)",
              "scale": {
                "domain": [
                  3.0,
                  3.4
                ],
                "nice": false
              }
            },
            "x2": {
              "datum": 3.0
            },
            "color": {
              "condition": {
                "test": "datum.is_best",
                "value": "#2D6A4F"
              },
              "value": "#9CA3AF"
            },
            "tooltip": [
              {
                "field": "dist",
                "type": "nominal",
                "title": "distribution"
              },
              {
                "field": "cv_ll",
                "type": "quantitative",
                "title": "log-lik / day"
              },
              {
                "field": "ratio",
                "type": "quantitative",
                "title": "vs Normal / day",
                "format": "+.1%"
              }
            ]
          }
        },
        {
          "mark": {
            "type": "text",
            "align": "left",
            "dx": 4,
            "fontSize": 11,
            "color": "#6B7280"
          },
          "encoding": {
            "y": {
              "field": "dist",
              "type": "nominal",
              "title": null,
              "sort": {
                "field": "cv_ll",
                "order": "descending"
              },
              "axis": {
                "labelFontSize": 13
              }
            },
            "x": {
              "field": "cv_ll",
              "type": "quantitative",
              "scale": {
                "domain": [
                  3.0,
                  3.4
                ],
                "nice": false
              }
            },
            "text": {
              "field": "cv_ll",
              "type": "quantitative",
              "format": ".3f"
            }
          }
        }
      ]
    },
    {
      "width": 170,
      "height": 240,
      "layer": [
        {
          "mark": {
            "type": "bar",
            "cornerRadiusEnd": 2
          },
          "encoding": {
            "y": {
              "field": "dist",
              "type": "nominal",
              "title": null,
              "sort": {
                "field": "cv_ll",
                "order": "descending"
              },
              "axis": null
            },
            "x": {
              "field": "ratio",
              "type": "quantitative",
              "title": "How much more likely per day than the Normal",
              "axis": {
                "format": "+.0%"
              },
              "scale": {
                "domain": [
                  0,
                  0.094872
                ],
                "nice": false
              }
            },
            "color": {
              "condition": {
                "test": "datum.is_best",
                "value": "#2D6A4F"
              },
              "value": "#9CA3AF"
            },
            "tooltip": [
              {
                "field": "dist",
                "type": "nominal",
                "title": "distribution"
              },
              {
                "field": "ratio",
                "type": "quantitative",
                "title": "vs Normal / day",
                "format": "+.1%"
              }
            ]
          }
        },
        {
          "mark": {
            "type": "text",
            "align": "left",
            "dx": 4,
            "fontSize": 11,
            "color": "#6B7280"
          },
          "encoding": {
            "y": {
              "field": "dist",
              "type": "nominal",
              "title": null,
              "sort": {
                "field": "cv_ll",
                "order": "descending"
              },
              "axis": null
            },
            "x": {
              "field": "ratio",
              "type": "quantitative",
              "scale": {
                "domain": [
                  0,
                  0.094872
                ],
                "nice": false
              }
            },
            "text": {
              "field": "ratio",
              "type": "quantitative",
              "format": "+.1%"
            }
          }
        }
      ]
    }
  ]
